generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Bots {
  id           Int       @id @default(autoincrement())
  name         String
  model        String?   @default("gpt-4o")
  instructions String?
  temperature  Float?    @default(0.5)
  top_p        Float?    @default(1)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  property_id  Int?

  properties Properties? @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bots_property_id_properties_id_fk")
  sources    Sources[]

  @@map("bots")
}

model Employees {
  id           Int       @id @default(autoincrement())
  name         String
  address      String?
  phone_number String    @unique(map: "employees_phone_number_unique") @db.VarChar
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  property_id  Int?

  properties Properties? @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "employees_property_id_properties_id_fk")
  tickets    Tickets[]

  @@map("employees")
}

model Messages {
  id          Int        @id @default(autoincrement())
  room_id     Int?
  sender_type SenderType
  content     String
  created_at  DateTime?  @default(now()) @db.Timestamp(6)
  property_id Int?

  properties Properties? @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "messages_property_id_properties_id_fk")
  rooms      Rooms?      @relation(fields: [room_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "messages_room_id_rooms_id_fk")

  @@map("messages")
}

model Properties {
  id         Int       @id @default(autoincrement())
  name       String
  address    String?
  created_at DateTime? @default(now()) @db.Timestamp(6)

  bots      Bots[]
  employees Employees[]
  messages  Messages[]
  rooms     Rooms[]
  tenants   Tenants[]
  units     Units[]
  whatsapp  Whatsapp[]
  tickets   Tickets[]

  @@map("properties")
}

model Rooms {
  id              Int        @id @default(autoincrement())
  tenant_id       Int?
  whatsapp_id     Int?
  tenant_number   String     @db.VarChar
  whatsapp_number String     @db.VarChar
  last_message    String?
  last_message_at DateTime?  @db.Timestamp(6)
  status          RoomStatus @default(active)
  created_at      DateTime?  @default(now()) @db.Timestamp(6)
  closed_at       DateTime?  @db.Timestamp(6)
  expired_at      DateTime   @db.Timestamp(6)
  property_id     Int?

  messages   Messages[]
  properties Properties? @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "rooms_property_id_properties_id_fk")
  tenants    Tenants?    @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "rooms_tenant_id_tenants_id_fk")
  whatsapp   Whatsapp?   @relation(fields: [whatsapp_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "rooms_whatsapp_id_whatsapp_id_fk")

  @@map("rooms")
}

model Sources {
  id         Int         @id @default(autoincrement())
  bot_id     Int?
  type       SourceType?
  title      String?
  content    String?
  created_at DateTime?   @default(now()) @db.Timestamp(6)

  bots Bots? @relation(fields: [bot_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "sources_bot_id_bots_id_fk")

  @@map("sources")
}

model Tenants {
  id           Int       @id @default(autoincrement())
  name         String
  address      String?
  phone_number String    @unique(map: "tenants_phone_number_unique") @db.VarChar
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  unit_id      Int?
  property_id  Int?

  rooms      Rooms[]
  properties Properties? @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tenants_property_id_properties_id_fk")
  unit       Units?      @relation(fields: [unit_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tenants_unit_id_units_id_fk")
  tickets    Tickets[]

  @@map("tenants")
}

model Tickets {
  id          Int            @id @default(autoincrement())
  property_id Int?
  category_id Int?
  tenant_id   Int?
  unit_id     Int?
  employee_id Int?
  title       String
  description String?
  status      TicketStatus   @default(open)
  priority    TicketPriority @default(low)
  created_at  DateTime?      @default(now()) @db.Timestamp(6)
  resolved_at DateTime?      @db.Timestamp(6)

  tenant     Tenants?          @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tickets_tenant_id_tenants_id_fk")
  properties Properties?       @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tickets_property_id_properties_id_fk")
  category   TicketCategories? @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tickets_category_id_ticket_category_id_fk")
  employee   Employees?        @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tickets_employee_id_employees_id_fk")
  unit       Units?            @relation(fields: [unit_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tickets_unit_id_units_id_fk")

  @@map("tickets")
}

model TicketCategories {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)

  tickets Tickets[]

  @@map("ticket_categories")
}

model Units {
  id          Int       @id @default(autoincrement())
  property_id Int?
  code        String
  created_at  DateTime? @default(now()) @db.Timestamp(6)

  properties Properties? @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "units_property_id_properties_id_fk")
  tenants    Tenants[]
  tickets    Tickets[]

  @@map("units")
}

model Users {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique(map: "users_email_unique") @db.VarChar
  password String @db.VarChar

  role UserRole

  @@map("users")
}

model Whatsapp {
  id             Int       @id @default(autoincrement())
  display_name   String
  waba_id        String    @unique(map: "whatsapp_waba_id_unique") @db.VarChar
  phone_id       String    @unique(map: "whatsapp_phone_id_unique") @db.VarChar
  phone_number   String    @unique(map: "whatsapp_phone_number_unique") @db.VarChar
  quality_rating String    @default("high") @db.VarChar
  created_at     DateTime? @default(now()) @db.Timestamp(6)

  rooms        Rooms[]
  properties   Properties? @relation(fields: [propertiesId], references: [id])
  propertiesId Int?

  @@map("whatsapp")
}

enum SenderType {
  tenant
  bot
  user

  @@map("sender_type")
}

enum SourceType {
  text
  file

  @@map("source_type")
}

enum TicketPriority {
  low
  medium
  high

  @@map("ticket_priority")
}

enum RoomStatus {
  active
  closed
  expired

  @@map("room_status")
}

enum TicketStatus {
  open
  in_progress @map("in-progress")
  closed

  @@map("ticket_status")
}

enum UserRole {
  super_admin @map("super-admin")

  @@map("user_role")
}
