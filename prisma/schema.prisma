generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id       Int    @id @default(autoincrement())
  name     String @db.VarChar(255)
  email    String @unique(map: "users_email_unique")
  password String @db.VarChar(255)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  role      UserRole
  employees Employees[]

  @@map("users")
}

model Whatsapp {
  id            Int    @id @default(autoincrement())
  displayName   String @map("display_name") @db.VarChar(255)
  wabaId        String @unique(map: "whatsapp_waba_id_unique") @map("waba_id")
  phoneId       String @unique(map: "whatsapp_phone_id_unique") @map("phone_id")
  phoneNumber   String @unique(map: "whatsapp_phone_number_unique") @map("phone_number") @db.VarChar(20)
  qualityRating String @default("high") @map("quality_rating")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  rooms Rooms[]

  @@map("whatsapp")
}

model Properties {
  id      Int     @id @default(autoincrement())
  name    String  @db.VarChar(255)
  address String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  bots      Bots[]
  employees Employees[]
  messages  Messages[]
  rooms     Rooms[]
  tenants   Tenants[]
  units     Units[]
  tickets   Tickets[]
  sources   Sources[]

  @@map("properties")
}

model Employees {
  id          Int     @id @default(autoincrement())
  userId      Int     @map("user_id")
  propertyId  Int     @map("property_id")
  address     String?
  phoneNumber String  @unique(map: "employees_phone_number_unique") @map("phone_number") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  property Properties @relation(fields: [propertyId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "employees_property_id_properties_id_fk")
  user     Users      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "employees_user_id_users_id_fk")
  tickets  Tickets[]

  @@map("employees")
}

model Units {
  id         Int    @id @default(autoincrement())
  propertyId Int    @map("property_id")
  code       String @db.VarChar(25)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  property Properties @relation(fields: [propertyId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "units_property_id_properties_id_fk")
  tenants  Tenants[]
  tickets  Tickets[]

  @@map("units")
}

model Tenants {
  id          Int     @id @default(autoincrement())
  propertyId  Int     @map("property_id")
  unitId      Int     @map("unit_id")
  name        String  @db.VarChar(255)
  address     String?
  phoneNumber String  @unique(map: "tenants_phone_number_unique") @map("phone_number") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  property Properties @relation(fields: [propertyId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tenants_property_id_properties_id_fk")
  unit     Units      @relation(fields: [unitId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tenants_unit_id_units_id_fk")
  rooms    Rooms[]
  tickets  Tickets[]

  @@map("tenants")
}

model Rooms {
  id            Int        @id @default(autoincrement())
  propertyId    Int        @map("property_id")
  tenantId      Int        @map("tenant_id")
  whatsappId    Int        @map("whatsapp_id")
  lastMessage   String?    @map("last_message")
  lastMessageAt DateTime?  @map("last_message_at")
  status        RoomStatus @default(active)
  closedAt      DateTime?  @map("closed_at")
  expiredAt     DateTime   @map("expired_at")

  createdAt DateTime @default(now()) @map("created_at")

  messages Messages[]
  property Properties @relation(fields: [propertyId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "rooms_property_id_properties_id_fk")
  tenant   Tenants    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "rooms_tenant_id_tenants_id_fk")
  whatsapp Whatsapp   @relation(fields: [whatsappId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "rooms_whatsapp_id_whatsapp_id_fk")

  @@map("rooms")
}

model Messages {
  id          Int           @id @default(autoincrement())
  propertyId  Int           @map("property_id")
  waId        String?       @unique @map("wa_id")
  roomId      Int           @map("room_id")
  senderType  SenderType    @map("sender_type")
  content     String
  messageType MessageType   @default(text) @map("message_type")
  status      MessageStatus @default(sent)

  createdAt DateTime @default(now()) @map("created_at")

  property Properties @relation(fields: [propertyId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "messages_property_id_properties_id_fk")
  room     Rooms      @relation(fields: [roomId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "messages_room_id_rooms_id_fk")

  @@map("messages")
}

model Tickets {
  id          Int            @id @default(autoincrement())
  propertyId  Int            @map("property_id")
  tenantId    Int            @map("tenant_id")
  unitId      Int            @map("unit_id")
  categoryId  Int            @map("category_id")
  employeeId  Int            @map("employee_id")
  title       String         @db.VarChar(255)
  description String?
  status      TicketStatus   @default(open)
  priority    TicketPriority @default(low)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  tenant   Tenants          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tickets_tenant_id_tenants_id_fk")
  property Properties       @relation(fields: [propertyId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tickets_property_id_properties_id_fk")
  category TicketCategories @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tickets_category_id_ticket_category_id_fk")
  employee Employees        @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tickets_employee_id_employees_id_fk")
  unit     Units            @relation(fields: [unitId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tickets_unit_id_units_id_fk")

  @@map("tickets")
}

model TicketCategories {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  tickets Tickets[]

  @@map("ticket_categories")
}

model Bots {
  id           Int    @id @default(autoincrement())
  propertyId   Int    @map("property_id")
  name         String @db.VarChar(255)
  model        String @default("gpt-4o")
  instructions String
  temperature  Float  @default(0.5)
  topP         Float  @default(1) @map("top_p")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  property Properties @relation(fields: [propertyId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bots_property_id_properties_id_fk")
  sources  Sources[]

  @@map("bots")
}

model Sources {
  id         Int        @id @default(autoincrement())
  propertyId Int        @map("property_id")
  botId      Int        @map("bot_id")
  type       SourceType @default(text)
  title      String     @db.VarChar(255)
  content    String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  property Properties @relation(fields: [propertyId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "sources_property_id_properties_id_fk")
  bot      Bots       @relation(fields: [botId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "sources_bot_id_bots_id_fk")

  @@map("sources")
}

enum SenderType {
  tenant
  bot
  user

  @@map("sender_type")
}

enum SourceType {
  text
  file

  @@map("source_type")
}

enum TicketPriority {
  low
  medium
  high

  @@map("ticket_priority")
}

enum RoomStatus {
  active
  closed
  expired

  @@map("room_status")
}

enum TicketStatus {
  open
  in_progress
  closed

  @@map("ticket_status")
}

enum MessageType {
  text
  image
  document
  audio
  video
  location

  @@map("message_type")
}

enum MessageStatus {
  sent
  delivered
  read
  failed

  @@map("message_status")
}

enum UserRole {
  super_admin
  dispatcher
  worker

  @@map("user_role")
}
